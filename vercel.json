{
  "version": 2,
  "functions": {
    "api/chat.js":     { "memory": 256, "maxDuration": 30 },
    "api/signup.js":   { "memory": 128, "maxDuration": 10 },
    "api/checkout.js": { "memory": 128, "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/chat",     "destination": "/api/chat.js"     },
    { "source": "/api/signup",   "destination": "/api/signup.js"   },
    { "source": "/api/checkout", "destination": "/api/checkout.js" }
  ]
}
